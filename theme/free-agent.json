{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg":        "#3e0136",
    "bgPanel":   "#161b22",
    "bgElement": "#1c2430",
    "border":    "#2a3441",
    "borderHi":  "#3d4d5c",
    "text":      "#cdd9e5",
    "muted":     "#6b7d8f",
    "primary":   "#4cc9f0",
    "secondary": "#4895ef",
    "accent":    "#f0a04c",
    "red":       "#f7768e",
    "amber":     "#e0af68",
    "green":     "#9ece6a",
    "magenta":   "#bb9af7",
    "cyan":      "#7dcfff",

    "lbg":        "#f4f7fa",
    "lbgPanel":   "#e9eef4",
    "lbgElement": "#dfe6ee",
    "lborder":    "#c4d0dc",
    "lborderHi":  "#95a7b8",
    "ltext":      "#1c2430",
    "lmuted":     "#5a6b7c",
    "lprimary":   "#0b7ea3",
    "lsecondary": "#1f6fb2",
    "laccent":    "#c26a12"
  },
  "theme": {
    "primary":            { "dark": "primary",   "light": "lprimary" },
    "secondary":          { "dark": "secondary", "light": "lsecondary" },
    "accent":             { "dark": "accent",    "light": "laccent" },
    "error":              { "dark": "red",       "light": "#b3261e" },
    "warning":            { "dark": "amber",     "light": "#8a6100" },
    "success":            { "dark": "green",     "light": "#2f7a2f" },
    "info":               { "dark": "primary",   "light": "lprimary" },
    "text":               { "dark": "text",      "light": "ltext" },
    "textMuted":          { "dark": "muted",     "light": "lmuted" },
    "background":         { "dark": "bg",        "light": "lbg" },
    "backgroundPanel":    { "dark": "bgPanel",   "light": "lbgPanel" },
    "backgroundElement":  { "dark": "bgElement", "light": "lbgElement" },
    "border":             { "dark": "border",    "light": "lborder" },
    "borderActive":       { "dark": "borderHi",  "light": "lborderHi" },
    "borderSubtle":       { "dark": "border",    "light": "lborder" },

    "diffAdded":            { "dark": "green",   "light": "#2f7a2f" },
    "diffRemoved":          { "dark": "red",     "light": "#b3261e" },
    "diffContext":          { "dark": "muted",   "light": "lmuted" },
    "diffHunkHeader":       { "dark": "muted",   "light": "lmuted" },
    "diffHighlightAdded":   { "dark": "green",   "light": "#2f7a2f" },
    "diffHighlightRemoved": { "dark": "red",     "light": "#b3261e" },
    "diffAddedBg":          { "dark": "#12261c", "light": "#dff0e0" },
    "diffRemovedBg":        { "dark": "#2a1519", "light": "#f6dce0" },
    "diffContextBg":        { "dark": "bgPanel", "light": "lbgPanel" },
    "diffLineNumber":       { "dark": "muted",   "light": "lmuted" },
    "diffAddedLineNumberBg":   { "dark": "#12261c", "light": "#dff0e0" },
    "diffRemovedLineNumberBg": { "dark": "#2a1519", "light": "#f6dce0" },

    "markdownText":           { "dark": "text",      "light": "ltext" },
    "markdownHeading":        { "dark": "primary",   "light": "lprimary" },
    "markdownLink":           { "dark": "secondary", "light": "lsecondary" },
    "markdownLinkText":       { "dark": "cyan",      "light": "lsecondary" },
    "markdownCode":           { "dark": "green",     "light": "#2f7a2f" },
    "markdownBlockQuote":     { "dark": "muted",     "light": "lmuted" },
    "markdownEmph":           { "dark": "accent",    "light": "laccent" },
    "markdownStrong":         { "dark": "amber",     "light": "#8a6100" },
    "markdownHorizontalRule": { "dark": "muted",     "light": "lmuted" },
    "markdownListItem":       { "dark": "primary",   "light": "lprimary" },
    "markdownListEnumeration":{ "dark": "cyan",      "light": "lsecondary" },
    "markdownImage":          { "dark": "secondary", "light": "lsecondary" },
    "markdownImageText":      { "dark": "cyan",      "light": "lsecondary" },
    "markdownCodeBlock":      { "dark": "text",      "light": "ltext" },

    "syntaxComment":     { "dark": "muted",     "light": "lmuted" },
    "syntaxKeyword":     { "dark": "magenta",   "light": "#7a3fb0" },
    "syntaxFunction":    { "dark": "primary",   "light": "lprimary" },
    "syntaxVariable":    { "dark": "cyan",      "light": "lsecondary" },
    "syntaxString":      { "dark": "green",     "light": "#2f7a2f" },
    "syntaxNumber":      { "dark": "accent",    "light": "laccent" },
    "syntaxType":        { "dark": "amber",     "light": "#8a6100" },
    "syntaxOperator":    { "dark": "secondary", "light": "lsecondary" },
    "syntaxPunctuation": { "dark": "text",      "light": "ltext" }
  }
}
