#!/usr/bin/env bash
#
# free-agent — idempotent one-shot: set up everything, then run the
# free_agent proxy and (if requested) keep it running.
#
# Does (only if needed):
#   1. venv creation (if absent)
#   2. pip install library + proxy deps (unless FA_SKIP_INSTALL=1)
#   3. .env from .env.example (skipped if .env already exists, unless --force)
#   4. ollama pull (the model in FA_MODEL from .env / defaults qwen3.6:35b)
#   5. OpenCode install (curl | bash)
#   6. writes ~/.config/opencode/opencode.json with the free-agent provider
#      (idempotent — merges if the key already exists)
#   7. places recall_turn.ts into the nearest tools/ directory
#   8. launches the proxy on FA_PROXY_HOST:FA_PROXY_PORT
#
# Usage:
#   ./free-agent [--force] [PROJECT_DIR]
#
# PROJECT_DIR (optional): the folder the interactive CLI should open when
#   FA_LAUNCH_CLI=1. Precedence: this arg > FA_CLI_DIR in .env > a native folder
#   picker (macOS osascript / Linux zenity|kdialog) > a text prompt > the
#   directory you ran this from. Proxy sessions are keyed per OpenCode
#   conversation, so separate conversations never interfere.
#
# Handy env toggles (may also live in .env):
#   FA_SKIP_INSTALL=1   skip pip install AND local Ollama setup (fast restarts)
#   FA_SKIP_OLLAMA=1    skip only the local Ollama install/serve/pull (use this
#                       for a REMOTE Ollama — pip install still runs). Point the
#                       proxy at the remote with OLLAMA_BASE_URL in .env.
#   OLLAMA_BASE_URL     upstream Ollama the proxy forwards to (default
#                       http://localhost:11434)
#   FA_PROXY_HOST       bind host (default 127.0.0.1); opencode.json + the recall
#                       tool are generated to match it (0.0.0.0/:: → loopback)
#   FA_PROXY_PORT       bind port (default 49786); opencode.json + the recall
#                       tool are generated to match it

set -euo pipefail

# Where the user launched us from — used as the default project folder for the
# CLI when FA_LAUNCH_CLI=1 and no explicit target is given. Captured BEFORE we
# cd into the repo, because the proxy itself must run from the repo root.
INVOKE_DIR="$PWD"

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

VENV_DIR="$ROOT_DIR/venv"
SOURCE_ENV="$ROOT_DIR/.env.example"
DEST_ENV="$ROOT_DIR/.env"
OPENCODE_CONFIG="$HOME/.config/opencode/opencode.json"
TOOLS_BASES=(
  "$HOME/.config/opencode/tools"
  "$ROOT_DIR/.opencode/tools"
)
# OpenCode loads custom themes from a `themes/` dir (global first, then
# project-local). Placing the file only makes the theme AVAILABLE; activation
# is handled separately in write_opencode_config so it can be non-destructive.
THEMES_BASES=(
  "$HOME/.config/opencode/themes"
  "$ROOT_DIR/.opencode/themes"
)

warn() { echo "[free-agent] WARNING: $*" >&2; }

# The address hosts (OpenCode, the recall tool) use to REACH the proxy. When the
# proxy binds 0.0.0.0 / :: (all interfaces) clients still connect over loopback.
proxy_connect_host() {
  local h="${FA_PROXY_HOST:-127.0.0.1}"
  if [ "$h" = "0.0.0.0" ] || [ "$h" = "::" ]; then h="127.0.0.1"; fi
  echo "$h"
}

expand_tilde() { printf '%s' "${1/#\~/$HOME}"; }

# Pop up a native "choose folder" dialog and print the chosen absolute path.
# Returns non-zero (prints nothing) if no GUI picker is available, there's no
# display, or the user cancels — callers then fall back to the text prompt.
# FA_CLI_PICKER=none disables it entirely (straight to the text prompt).
pick_dir_gui() {
  [ "${FA_CLI_PICKER:-auto}" = "none" ] && return 1
  local path="" prompt="Choose the project folder for the CLI"
  case "$(uname -s)" in
    Darwin*)
      command -v osascript &>/dev/null || return 1
      # try/end try so a Cancel (AppleScript error -128) yields "" instead of
      # a non-zero osascript exit we'd have to special-case.
      path="$(osascript \
        -e 'try' \
        -e "POSIX path of (choose folder with prompt \"$prompt\")" \
        -e 'end try' 2>/dev/null)" || return 1
      ;;
    Linux*)
      if command -v zenity &>/dev/null; then
        path="$(zenity --file-selection --directory --title="$prompt" 2>/dev/null)" || return 1
      elif command -v kdialog &>/dev/null; then
        path="$(kdialog --title "$prompt" --getexistingdirectory "$HOME" 2>/dev/null)" || return 1
      else
        return 1
      fi
      ;;
    *) return 1 ;;
  esac
  path="${path%/}"          # osascript appends a trailing slash to folders
  [ -n "$path" ] || return 1
  printf '%s' "$path"
}

# Resolve the folder the CLI should open (absolute path on stdout). Precedence:
# positional arg > FA_CLI_DIR > native folder picker > text prompt > invoke dir.
resolve_cli_dir() {
  local dir=""
  if [ -n "${TARGET_DIR:-}" ]; then
    dir="$TARGET_DIR"
  elif [ -n "${FA_CLI_DIR:-}" ]; then
    dir="$FA_CLI_DIR"
  else
    # Native picker first (friendliest); fall back to typing a path.
    dir="$(pick_dir_gui || true)"
    if [ -z "$dir" ] && [ -t 0 ]; then
      printf '\n[free-agent] Which project folder should the CLI open?\n  [Enter = %s]: ' "$INVOKE_DIR" >&2
      read -r dir || true
    fi
    [ -z "$dir" ] && dir="$INVOKE_DIR"
  fi
  dir="$(expand_tilde "$dir")"
  if [ -d "$dir" ]; then
    ( cd "$dir" && pwd )
  else
    warn "project folder '$dir' does not exist — using $INVOKE_DIR instead"
    echo "$INVOKE_DIR"
  fi
}

install_with_brew() {
  if ! command -v brew &>/dev/null; then
    warn "Homebrew not found — install it at https://brew.sh (then re-run this script)"
    return 1
  fi
  brew install "$@"
}

check_and_install_pkg() {
  local cmd=$1 brew_pkg=$2 os prompt_msg="${3:-$cmd}"
  if command -v "$cmd" &>/dev/null; then
    return 0
  fi

  echo "[free-agent] $prompt_msg not found — installing …"
  os=$(uname -s)

  case "$os" in
    Darwin*)
      # Try xcode-select --install for curl on macOS without CLT
      if [[ "$cmd" == *curl* ]] && ! xcode-select -p &>/dev/null; then
        echo "[free-agent] installing Xcode Command Line Tools (provides curl) …"
        xcode-select --install 2>/dev/null || { warn "xcode-select failed — install manually"; return 1; }
        if command -v "$cmd" &>/dev/null; then return 0; fi
      fi
      install_with_brew "$brew_pkg"
      ;;
    Linux*)
      case "$cmd" in
        git) sudo apt-get update && sudo apt-get install -y git ;;
        curl) sudo apt-get update && sudo apt-get install -y curl ;;
        python3) sudo apt-get update && sudo apt-get install -y python3 ;;
      esac
      ;;
    *)
      warn "$prompt_msg not found and I can't auto-install on $(echo "$os" | tr a-z A-Z). Please install it manually."
      return 1
      ;;
  esac

  if command -v "$cmd" &>/dev/null; then
    echo "  [ok] $prompt_msg installed"
    return 0
  else
    warn "$prompt_msg could not be installed — check for errors above"
    return 1
  fi
}

ensure_system_pkgs() {
  local fail=0
  check_and_install_pkg python3 python   "Python (python3)" || fail=1
  check_and_install_pkg git   git        "Git"              || fail=1
  check_and_install_pkg curl  curl       "curl"             || fail=1

  if [ "$fail" -eq 1 ]; then
    echo ""
    warn "Some dependencies could not be installed automatically. Fix the issues above and re-run."
    exit 1
  fi
}

# ---------- helpers -----------------------------------------------------------
ensure_venv() {
  if [ -x "$VENV_DIR/bin/python" ]; then
    return 0
  fi
  echo "[free-agent] creating virtualenv at $VENV_DIR"
  python3 -m venv "$VENV_DIR"
}

install_deps() {
  if [ "${FA_SKIP_INSTALL:-0}" = "1" ]; then
    echo "[free-agent] skipping install (FA_SKIP_INSTALL=1)"
    return 0
  fi
  source "$VENV_DIR/bin/activate"
  pip install -q -e .
  pip install -q fastapi uvicorn httpx
}

ensure_env() {
  local force="${1:-}"
  if [ -f "$DEST_ENV" ] && [ "$force" != "--force" ]; then
    echo "[free-agent] .env already exists — skipping write (use --force to overwrite)"
    return 0
  fi
  if [ ! -f "$SOURCE_ENV" ]; then
    warn ".env.example not found; skipping .env setup"
    return 0
  fi
  cp "$SOURCE_ENV" "$DEST_ENV"
  echo "[free-agent] copied .env.example -> .env"
}

# shellcheck disable=SC1091
load_env() {
  if [ -f "$DEST_ENV" ]; then
    echo "[free-agent] loading .env"
    set -a
    source "$DEST_ENV"
    set +a
  fi
}

ensure_ollama_installed() {
   local os=$1
   local model="${FA_MODEL:-qwen3.6:35b}"

   # ---------- install if absent -------------------------------------------------
   if ! command -v ollama &>/dev/null; then
     echo "[free-agent] ollama not found — installing …"
     case "$os" in
       Darwin*) install_with_brew ollama || { warn "Failed to install ollama via brew"; return 1; } ;;
       Linux*)
         curl -fsSL https://ollama.com/install.sh | sh || { warn "Failed to install ollama manually"; return 1; }
         # Ensure binary is on PATH (installer may put it in /usr/local/bin)
         export PATH="/usr/local/bin:$PATH"
         ;;
       *)
         warn "Cannot auto-install ollama on $(echo "$os" | tr a-z A-Z). Please install it from https://ollama.com";
         return 1
         ;;
     esac
     if ! command -v ollama &>/dev/null; then
       warn "ollama binary not found after install — check your PATH."
       echo "   Hint: source ~/.zshrc (or restart your terminal) and re-run this script."
       return 1
     fi
     echo "[ok] ollama installed"
   else
     echo "[free-agent] ollama already installed ($(ollama --version 2>/dev/null || echo 'unknown'))"
   fi

   # ---------- detect daemon state (process + port) ------------------------------
   local running=false
   if pgrep -f ollama &>/dev/null || curl -sf http://127.0.0.1:11434/ &>/dev/null; then
     running=true
   fi

   # ---------- check for managed services ──────────── (launchd / systemd) -------
   local service_exists=false
   if [ "$os" = "Darwin" ]; then
     if brew services list 2>/dev/null | grep -q ollama; then
       service_exists=true
     elif launchctl list com.github.ollama.ollama &>/dev/null; then
       service_exists=true
     fi
   else
     if systemctl is-active --quiet ollama 2>/dev/null || systemctl is-active --quiet ollama.service 2>/dev/null; then
       service_exists=true
     fi
   fi

   if [ "$running" = true ]; then
     echo "[free-agent] ollama daemon is already running (port 11434 reachable)"
   elif [ "$service_exists" = true ]; then
     echo "[free-agent] ollama service detected but not responding — waiting up to 20 s …"
     local retries=40
     while [ "$retries" -gt 0 ]; do
       if curl -sf http://127.0.0.1:11434/ &>/dev/null; then
         running=true
         break
       fi
       sleep 0.5
       retries=$((retries - 1))
     done
     if [ "$running" = true ]; then
       echo "[ok] ollama service is now reachable (port 11434)"
     else
       warn "ollama service still unreachable after 20 s — start it manually ('ollama serve') and re-run."
       return 1
     fi
   else
     # Not running, no managed service → start daemon ourselves
     echo "[free-agent] ollama installed but the daemon is not running — starting …"
     ollama serve &>/dev/null &
     local _OLLA_MA_PID=$!
     echo "   started ollama (PID $_OLLA_MA_PID)"
     sleep 3

     if curl -sf http://127.0.0.1:11434/ &>/dev/null; then
       echo "[ok] ollama daemon is now running on port 11434"
     else
       warn "ollama serve was triggered but the daemon hasn't bound port 11434 yet."
       echo "   Try 'ollama serve' manually; re-run this script when it's healthy."
       return 1
     fi
   fi

   # ---------- pull / verify model -----------------------------------------------
   if ollama list 2>/dev/null | grep -qF "$model"; then
     echo "[free-agent] model '$model' is already available — skipping pull"
   else
     echo "[free-agent] pulling model: $model"
     ollama pull "$model" || { warn "ollama pull failed for $model (may need network connectivity)"; }
   fi

   return 0
}

ensure_opencode() {
  if command -v opencode &>/dev/null; then
    return 0
  fi
  echo "[free-agent] installing OpenCode ..."
  curl -fsSL https://opencode.ai/install | bash
}

write_opencode_config() {
  # The model id here is cosmetic — the proxy overrides body["model"] with
  # FA_MODEL — but track FA_MODEL so /models displays the model actually in use.
  local model="${FA_MODEL:-qwen3.6:35b}"
  # Point OpenCode at wherever the proxy will actually bind (defaults match the
  # proxy's own defaults). Change FA_PROXY_PORT in .env and this follows it.
  local host port
  host="$(proxy_connect_host)"
  port="${FA_PROXY_PORT:-49786}"
  local provider_block="
    \"free-agent\": {
      \"npm\": \"@ai-sdk/openai-compatible\",
      \"name\": \"Ollama (via free_agent)\",
      \"options\": {
        \"baseURL\": \"http://$host:$port/v1\",
        \"headers\": { \"x-session-id\": \"opencode\" }
      },
      \"models\": { \"$model\": { \"name\": \"$model (via free_agent)\" } }
    }"

  mkdir -p "$(dirname "$OPENCODE_CONFIG")"

  if [ -f "$OPENCODE_CONFIG" ]; then
    if python3 -c "import json,sys; json.load(open(sys.argv[1]))" "$OPENCODE_CONFIG" &>/dev/null; then
      local new_providers
      new_providers=$(python3 -c "
import json, sys

with open(sys.argv[1]) as f:
    cfg = json.load(f)

cfg.setdefault('provider', {})['free-agent'] = $provider_block
# Pin the default model to the proxy provider so a fresh OpenCode session
# starts pointing at free-agent — not at whatever it last used (which, after a
# provider rename, silently falls back to a built-in model and bypasses the
# proxy). This is the configured default; the user can still switch via /models.
cfg['model'] = 'free-agent/$model'
# Activate the bundled theme only if the user hasn't already chosen one, so we
# never clobber an existing theme preference.
cfg.setdefault('theme', 'free-agent')
json.dump(cfg, sys.stdout, indent=2)
" "$OPENCODE_CONFIG" 2>/dev/null || true)
      if [ -n "$new_providers" ]; then
        echo "$new_providers" > "$OPENCODE_CONFIG"
        echo "[free-agent] updated $OPENCODE_CONFIG (injected free-agent provider)"
        return 0
      fi
    fi
  fi

  cat > "$OPENCODE_CONFIG" <<EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "theme": "free-agent",
  "model": "free-agent/$model",
  "provider": {
$provider_block
  }
}
EOF
  echo "[free-agent] wrote $OPENCODE_CONFIG"
}

place_recall_tool() {
  local tool_src="$ROOT_DIR/tools/recall_turn.ts"

  # If the repo doesn't ship a tools/recall_turn.ts, generate the canonical one
  # (kept in sync with the "Add the recall tool" section of the README).
  if [ ! -f "$tool_src" ]; then
    echo "[free-agent] tools/recall_turn.ts not found in repo — generating it"
    mkdir -p "$(dirname "$tool_src")"
    cat > "$tool_src" <<'TS'
import { tool } from "@opencode-ai/plugin"

export default tool({
  description:
    "Fetch the full, uncompressed detail of an earlier turn by its archive " +
    "key. Summaries in the history end with '(recall: turn-NNNN)' — pass that " +
    "key here when a summary isn't enough.",
  args: {
    key: tool.schema.string().describe("Archive key, e.g. 'turn-0003'"),
  },
  async execute(args, context) {
    // context.sessionID matches the x-session-id the proxy keyed the archive on.
    const res = await fetch("http://127.0.0.1:49786/recall", {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify({ session: context.sessionID, key: args.key }),
    })
    const data = await res.json()
    return data.text ?? "No archived turn found."
  },
})
TS
  fi

  # The recall tool runs inside OpenCode, not this shell, so it can't read
  # FA_PROXY_PORT at runtime — bake the proxy's actual address into the file.
  local host port recall_url
  host="$(proxy_connect_host)"
  port="${FA_PROXY_PORT:-49786}"
  recall_url="http://$host:$port/recall"

  # Rewrite only the /recall server address — the tool body itself is never
  # touched. The address is deployment config (it follows FA_PROXY_HOST/PORT);
  # the tool definition is not. So we sync the URL in EVERY existing
  # recall_turn.ts on every run, and place one if none exists yet.
  sync_recall_url() {
    local f=$1
    # Match any scheme://host:port/recall, so a previously-written custom host
    # (not just loopback) is re-synced when the port/host changes.
    sed -i.bak -E "s#https?://[^\"']+/recall#$recall_url#g" "$f" && rm -f "$f.bak"
  }

  local placed=false existing=false
  for dir in "${TOOLS_BASES[@]}"; do
    local dest="$dir/recall_turn.ts"
    if [ -f "$dest" ]; then
      sync_recall_url "$dest"
      echo "[free-agent] synced recall_turn.ts URL -> $dest (recall → $recall_url)"
      existing=true
    fi
  done

  # No recall_turn.ts anywhere yet → place one in the first available dir.
  if [ "$existing" = false ]; then
    for dir in "${TOOLS_BASES[@]}"; do
      mkdir -p "$dir"
      local dest="$dir/recall_turn.ts"
      cp "$tool_src" "$dest"
      sync_recall_url "$dest"
      echo "[free-agent] placed recall_turn.ts -> $dest (recall → $recall_url)"
      placed=true
      break
    done
    [ "$placed" = true ] || warn "could not place recall_turn.ts in any tools/ directory"
  fi
}

place_theme() {
  local theme_src="$ROOT_DIR/theme/free-agent.json"

  # Ship the theme in the repo; if it's missing there's nothing to place.
  if [ ! -f "$theme_src" ]; then
    warn "theme/free-agent.json not found in repo — skipping custom theme"
    return 0
  fi

  # Copy into the first available themes dir (global first). This only makes the
  # theme selectable (via /theme or config); write_opencode_config activates it.
  local dir dest placed=false
  for dir in "${THEMES_BASES[@]}"; do
    mkdir -p "$dir" || continue
    dest="$dir/free-agent.json"
    if cp "$theme_src" "$dest"; then
      echo "[free-agent] placed theme -> $dest"
      placed=true
      break
    fi
  done
  [ "$placed" = true ] || warn "could not place free-agent.json in any themes/ directory"
}

# ---------- main --------------------------------------------------------------
FORCE=""
TARGET_DIR=""
for arg in "$@"; do
  case "$arg" in
    --force) FORCE="$arg" ;;
    -*)      warn "ignoring unknown option: $arg" ;;
    *)       TARGET_DIR="$arg" ;;   # a project folder for the CLI to open
  esac
done

echo ""
echo "=========================================="
echo "  Setting up free-agent …"
echo "=========================================="

ensure_system_pkgs  && echo "[ok] system"
ensure_venv          && echo "[ok] venv"
install_deps         && echo "[ok] deps installed"
ensure_env "$FORCE"  && echo "[ok] .env"
# Load .env NOW, before anything reads FA_MODEL — the model pull and the
# opencode.json write both depend on it, so a model chosen in .env is honored.
load_env

# Resolve the CLI's project folder up front — asking the user now, before the
# unattended install/pull steps. Proxy sessions are keyed per OpenCode
# conversation (OpenCode sends its own x-session-id), so distinct conversations
# stay isolated regardless of which folder the CLI opens.
CLI_DIR=""
if [ "${FA_LAUNCH_CLI:-0}" = "1" ]; then
  CLI_DIR="$(resolve_cli_dir)"
  echo "[free-agent] CLI will open: $CLI_DIR"
fi

# Skip the local-Ollama install/serve/pull dance when asked. FA_SKIP_OLLAMA is
# the targeted switch (use it for a REMOTE Ollama: no local daemon, but pip
# install still runs). FA_SKIP_INSTALL implies it too, for backward-compat.
if [ "${FA_SKIP_OLLAMA:-0}" = "1" ] || [ "${FA_SKIP_INSTALL:-0}" = "1" ]; then
  echo "[free-agent] skipping local Ollama setup (FA_SKIP_OLLAMA/FA_SKIP_INSTALL=1)"
else
  ensure_ollama_installed "$(uname -s)" && echo "[ok] Ollama primed"
fi
ensure_opencode      && echo "[ok] OpenCode"
write_opencode_config && echo "[ok] opencode.json"
place_recall_tool    && echo "[ok] recall tool"
place_theme          && echo "[ok] theme"

# Activate the venv for the proxy launch (.env is already loaded above).
source "$VENV_DIR/bin/activate"

HOST="${FA_PROXY_HOST:-127.0.0.1}"
PORT="${FA_PROXY_PORT:-49786}"

echo ""
echo "=========================================="
echo "  Proxy starting on http://$HOST:$PORT"
echo "=========================================="

if [ "${FA_LAUNCH_CLI:-0}" = "1" ]; then
  # Run the proxy in the background, wait until it's reachable, then hand this
  # same terminal to an interactive CLI session. Quitting the CLI tears the
  # proxy down (via the EXIT trap), so one terminal window = one full session.
  CLI_CMD="${FA_CLI_CMD:-opencode}"
  CONNECT_HOST="$(proxy_connect_host)"

  # Redirect all proxy / uvicorn output to a log file so it doesn't overlay
  # the interactive opencode session. The user can still follow logs with:
  #   tail -f ~/.free_agent/proxy.log  (or see the location printed below).
  PROXY_LOG="${FA_PROXY_LOG:-${HOME}/.free_agent/proxy.log}"
  mkdir -p "$(dirname "$PROXY_LOG")"
  uvicorn examples.fa_proxy:app --host "$HOST" --port "$PORT" >>"$PROXY_LOG" 2>&1 &
  PROXY_PID=$!
  trap 'kill "$PROXY_PID" 2>/dev/null || true' EXIT

  echo "[free-agent] waiting for the proxy to accept connections …"
  retries=40
  while [ "$retries" -gt 0 ]; do
    # No -f: the proxy has no health route, so any HTTP response (even 404)
    # means it's up. curl only fails to connect (exit 7) while it's still down.
    if curl -s "http://$CONNECT_HOST:$PORT/" &>/dev/null; then
      break
    fi
    # Bail early if the proxy died on startup instead of spinning the full 20 s.
    if ! kill -0 "$PROXY_PID" 2>/dev/null; then
      warn "proxy exited before it came up — check the output above."
      exit 1
    fi
    sleep 0.5
    retries=$((retries - 1))
  done

  echo "[free-agent] launching CLI in $CLI_DIR: $CLI_CMD  (quit it to stop the proxy)"
  # Set the terminal window/tab title so our branding shows alongside the CLI's
  # own banner for the whole session. opencode has no config for banner text, but
  # the OSC 0 escape sets the title at the terminal level and survives the TUI's
  # alternate-screen switch. Override the text with FA_TERM_TITLE; set it empty to
  # skip. Only emitted to an interactive TTY so it never lands in logs/pipes.
  #
  # opencode itself rewrites the terminal title reactively (to "OpenCode" / the
  # session name) once its TUI mounts, which would clobber ours after a fraction
  # of a second. OPENCODE_DISABLE_TERMINAL_TITLE=1 turns those updates off so our
  # title sticks; we only set it when we actually have a title to protect.
  TERM_TITLE="${FA_TERM_TITLE-Empromptu FreeAgent - The Free, Optimized Coding Agent}"
  if [ -n "$TERM_TITLE" ] && [ -t 1 ]; then
    printf '\033]0;%s\007' "$TERM_TITLE"
    export OPENCODE_DISABLE_TERMINAL_TITLE=1
  fi
  # Open the CLI in the chosen project folder (a subshell, so our cwd stays the
  # repo root for the proxy). Don't let a non-zero CLI exit (e.g. Ctrl-C) abort
  # before the EXIT trap runs.
  ( cd "$CLI_DIR" && exec $CLI_CMD ) || true
else
  exec uvicorn examples.fa_proxy:app --host "$HOST" --port "$PORT"
fi
